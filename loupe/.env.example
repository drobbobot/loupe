# ─────────────────────────────────────────────
# Loupe — Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────

# Supabase
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to client

# Sanity
# Found at: https://www.sanity.io/manage/personal/project/<your-project-id>/api
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production             # or 'development' locally
SANITY_API_TOKEN=your-api-token                   # read-write token, server-side only

# Stripe
# Found at: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...                     # server-side only
STRIPE_WEBHOOK_SECRET=whsec_...                   # from Stripe CLI or dashboard

# Stripe Price IDs
# Create these in Stripe dashboard: Products → Add product → Add price
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000          # set to https://loupe.app in production

# Resend (transactional email)
# Found at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Upstash Redis (optional at < 50 users — see architecture.md §3.8)
# Found at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
